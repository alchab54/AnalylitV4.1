# STAGE 1: Builder - Installe les dépendances
FROM python:3.11-slim as builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN python -m pip install --upgrade pip setuptools wheel

WORKDIR /app
# ÉTAPE CLÉ : Copie et installe les dépendances EN PREMIER
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt


# STAGE 2: Final - Image d'exécution
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copie l'environnement virtuel pré-construit
COPY --from=builder /opt/venv /opt/venv

ENV PATH="/opt/venv/bin:$PATH"

WORKDIR /app
# ÉTAPE CLÉ : Copie le reste du code de l'application
COPY . .

CMD ["python", "-m", "rq", "worker", "-c", "config_v4", "high", "default", "low", "--with-scheduler"]