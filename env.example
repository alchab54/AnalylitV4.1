# AnalyLit V4.0 - Configuration d'Environnement
# Adapté pour une configuration de développement sur Windows 11
# GPU: NVIDIA RTX 2060 SUPER | CPU: AMD Ryzen 7 3700X | RAM: 16 Go

# ===== INFORMATIONS GÉNÉRALES =====
ANALYLIT_VERSION=4.0.0
APP_NAME=AnalyLit
APP_DESCRIPTION="Plateforme d'analyse de littérature scientifique avec IA"

# ===== CONFIGURATION FLASK =====
FLASK_ENV=development
# L'application tournera en mode développement, plus verbeux et avec des outils de debug.
# Pour la production, vous passerez à 'production'.
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
FLASK_DEBUG=true
# SECRET_KEY est crucial pour la sécurité. Générez la vôtre avec la commande en bas du fichier.
SECRET_KEY=8cfb18e58a85676a34a6658a0263b48b85c7479edb807f38

# ===== CONFIGURATION REDIS =====
# C'est la configuration par défaut si vous lancez Redis via Docker sans mot de passe.
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Laissez vide si vous n'avez pas de mot de passe Redis.

# ===== CONFIGURATION OLLAMA =====
# Assurez-vous que Ollama tourne sur votre machine et est accessible à cette URL.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=900
OLLAMA_MAX_RETRIES=3

# ===== RÉPERTOIRES DE DONNÉES =====
# Sous Windows, il est préférable de ne pas utiliser des chemins type /app.
# Créez un dossier à la racine de votre projet ou à un emplacement connu.
# Exemple pour un projet situé dans C:\Users\VotreNom\projets\analylit
PROJECTS_DIR=./data/projects
LOGS_DIR=./data/logs
TEMP_DIR=./data/tmp
BACKUP_DIR=./data/backups
# Le script créera ces dossiers s'ils n'existent pas.

# ===== CONFIGURATION BASE DE DONNÉES =====
# L'URL sqlite doit référencer le chemin défini dans PROJECTS_DIR.
DATABASE_URL=sqlite:///./data/projects/database.db
DATABASE_TIMEOUT=30.0
DATABASE_POOL_SIZE=20

# ===== CONFIGURATION HTTP =====
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE=1.6
HTTP_TIMEOUT=30
HTTP_USER_AGENT="AnalyLit/4.0 (Windows; Development)"

# ===== CONFIGURATION APIS EXTERNES =====
# Un email est nécessaire pour utiliser l'API Unpaywall de manière polie.
UNPAYWALL_EMAIL=alicechabaux@gmail.com
# L'API Key de PubMed n'est pas obligatoire mais recommandée pour éviter d'être limité.
PUBMED_API_KEY=
# Email de contact pour l'API CrossRef.
CROSSREF_API_EMAIL=alicechabaux@gmail.com
# L'API Key IEEE est nécessaire pour interroger cette base.
IEEE_API_KEY=

# ===== CONFIGURATION ZOTERO (VOS IDENTIFIANTS) =====
ZOTERO_USER_ID=8926142
ZOTERO_API_KEY=NaqpuvV9xxfJArJRWgYMDlYs
ZOTERO_LIBRARY_TYPE=user
ZOTERO_MAX_ITEMS=100

# ===== CONFIGURATION EMBEDDINGS & GPU =====
# Votre RTX 2060 SUPER est parfaite pour les embeddings. Mettons USE_GPU à true.
USE_GPU=true
# Normalement, PyTorch/CUDA gère bien l'allocation, mais vous pouvez forcer le GPU 0.
CUDA_VISIBLE_DEVICES=0
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBED_BATCH_SIZE=32
MIN_CHUNK_LENGTH=250
MAX_CHUNK_LENGTH=1000
CHUNK_OVERLAP=200
USE_GPU_EMBEDDINGS=true

# ===== CONFIGURATION VECTORIELLE =====
USE_QUERY_EMBEDDINGS=true
VECTOR_SIMILARITY_THRESHOLD=0.7
MAX_SEARCH_RESULTS=10
NORMALIZE_TEXT=true
NORMALIZE_LOWERCASE=false

# ===== CONFIGURATION PROCESSING =====
# Votre Ryzen 7 a 8 cœurs. Utiliser la moitié pour les workers est un bon début.
MAX_WORKERS=4
WORKER_TIMEOUT=3600
JOB_TIMEOUT=1800
QUEUE_TTL=86400

# ===== CONFIGURATION LOGGING =====
LOG_LEVEL=INFO
# En développement, on peut aussi utiliser DEBUG pour plus de détails.
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE=./data/logs/analylit.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# ===== CONFIGURATION SÉCURITÉ (POUR LE DEV LOCAL) =====
CORS_ORIGINS=*
# "*" est OK pour le développement, mais devra être restreint en production.
RATE_LIMIT_ENABLED=false
# Inutile d'activer la limitation de taux en local.
MAX_UPLOAD_SIZE=100MB

# ===== CONFIGURATION DOCKER (INFORMATIF) =====
# Ces variables sont généralement passées au conteneur Docker.
# Votre Ryzen 7 et 16 Go de RAM sont suffisants.
CONTAINER_MEMORY_LIMIT=8g
# On peut allouer plus de RAM car vous en avez 16 Go.
CONTAINER_CPU_LIMIT=4
# On peut allouer jusqu'à 4 cœurs CPU.

# ===== VARIABLES SYSTÈME =====
# Important pour la cohérence des dates et de l'encodage.
TZ=Europe/Paris
LANG=fr_FR.UTF-8
PYTHONPATH=/app
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1

# ===== CONFIGURATION DÉVELOPPEMENT =====
# Ces options sont utiles pour le débogage.
DEV_MODE=true
RELOAD_ON_CHANGE=true
PROFILE_PERFORMANCE=false
DEBUG_WEBSOCKETS=true
