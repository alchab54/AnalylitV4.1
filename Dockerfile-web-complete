# AnalyLit V4.0 - Dockerfile pour le serveur web (VERSION FINALE STABLE ET RAPIDE)
# Utilise l'image de base personnalisée pour des builds plus rapides

FROM analylit-base:latest

# --- 1. Reste de l'application ---
# Ces fichiers peuvent changer sans invalider le cache des dépendances de base
COPY config_v4.py .
COPY server_v4_complete.py .
COPY tasks_v4_complete.py .
COPY web/ ./web/

# --- 2. Configuration finale ---
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV CUDA_VISIBLE_DEVICES=0
ENV USE_GPU=true
ENV FLASK_APP=server_v4_complete.py

RUN mkdir -p /app/projects /app/model_cache
ENV SENTENCE_TRANSFORMERS_HOME=/app/model_cache

EXPOSE 5001
# La commande de démarrage est maintenant dans docker-compose-local.yml
# CMD ["python", "server_v4_complete.py"]
