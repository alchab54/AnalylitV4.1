# AnalyLit V4.1 - Dockerfile pour le serveur web (hérite de l'image de base)

# --- Étape 1: Builder - Installe les dépendances ---
FROM nvidia/cuda:12.3.1-runtime-ubuntu22.04 as builder

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Paris
ENV PYTHONUNBUFFERED=1

# Installation des dépendances système et Python 3.11
# Inclut les outils de build qui ne seront pas dans l'image finale
RUN apt-get update && apt-get install -y --no-install-recommends \
    software-properties-common \
    tzdata \
    && add-apt-repository ppa:deadsnakes/ppa -y \
    && apt-get update && apt-get install -y --no-install-recommends \
    python3.11 python3.11-dev python3.11-venv python3-pip \
    gcc g++ curl build-essential git libgl1-mesa-glx libglib2.0-0 libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Création d'un environnement virtuel
RUN python3.11 -m venv /opt/venv
# Active le venv pour les commandes suivantes
ENV PATH="/opt/venv/bin:$PATH" 
RUN python -m pip install --upgrade pip setuptools wheel

WORKDIR /app

# Installation des dépendances Python dans le venv
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# --- Étape 2: Production - Création de l'image finale ---
FROM nvidia/cuda:12.3.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Paris
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

# Installation des dépendances d'exécution uniquement (plus léger)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.11-venv libgl1-mesa-glx libglib2.0-0 libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Copie de l'environnement virtuel avec les dépendances déjà installées depuis le builder
COPY --from=builder /opt/venv /opt/venv

# Activation du venv pour l'image finale
ENV PATH="/opt/venv/bin:$PATH"

# Configuration de l'application
WORKDIR /app
COPY requirements.txt ./
COPY . .
RUN mkdir -p /app/projects /app/model_cache
ENV SENTENCE_TRANSFORMERS_HOME=/app/model_cache
ENV NVIDIA_VISIBLE_DEVICES=all
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV CUDA_VISIBLE_DEVICES=0
ENV USE_GPU=true
ENV FLASK_APP=server_v4_complete.py

EXPOSE 5001
# La commande de démarrage est dans docker-compose-local.yml
