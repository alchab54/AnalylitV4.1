# STAGE 1: Builder - Installe les dépendances dans un environnement virtuel
FROM python:3.11-slim as builder

# Installe les paquets système nécessaires pour la compilation
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Création d'un environnement virtuel
RUN python -m venv /opt/venv
# Active le venv pour les commandes suivantes
ENV PATH="/opt/venv/bin:$PATH"

# Met à jour pip
RUN python -m pip install --upgrade pip setuptools wheel

WORKDIR /app
# Installation des dépendances Python dans le venv
# ÉTAPE CLÉ : Copie et installe les dépendances EN PREMIER
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt


# STAGE 2: Final - Construit l'image finale légère
FROM python:3.11-slim

# Installation des dépendances d'exécution uniquement (plus léger)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# Copie de l'environnement virtuel avec les dépendances déjà installées depuis le builder
COPY --from=builder /opt/venv /opt/venv

# Activation du venv pour l'image finale
# Définit le chemin pour utiliser l'environnement virtuel
ENV PATH="/opt/venv/bin:$PATH"

# Configuration de l'application
WORKDIR /app
# ÉTAPE CLÉ : Copie le reste du code de l'application SEULEMENT MAINTENANT
COPY . .

# Crée les répertoires nécessaires
RUN mkdir -p /app/projects /app/model_cache

EXPOSE 5000
CMD ["/bin/bash", "-c", "python -c 'from utils.database import init_db; init_db()' && gunicorn --workers 4 --bind 0.0.0.0:5000 'server_v4_complete:create_app()'"]
